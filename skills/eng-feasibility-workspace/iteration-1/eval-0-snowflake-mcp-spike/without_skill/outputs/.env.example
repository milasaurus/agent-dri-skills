# Snowflake — service account for the spike. Prod will need per-user auth.
SNOWFLAKE_ACCOUNT=xy12345.us-east-1
SNOWFLAKE_USER=mcp_spike_svc
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=MCP_SPIKE_READONLY
SNOWFLAKE_WAREHOUSE=MCP_SPIKE_WH
SNOWFLAKE_DATABASE=ANALYTICS
SNOWFLAKE_SCHEMA=PUBLIC

# Anthropic — used by the rewriter to inspect EXPLAIN plans.
ANTHROPIC_API_KEY=
REWRITER_MODEL=claude-opus-4-5

# Spike guardrails
REWRITER_COST_THRESHOLD_BYTES=1073741824   # 1 GiB scanned — below this, skip rewrite
REWRITER_MAX_RETRIES=2
QUERY_TIMEOUT_SECONDS=60
